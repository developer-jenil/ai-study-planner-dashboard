PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/study_planner?retryWrites=true&w=majority
JWT_SECRET=your_jwt_secret_key_here

# PostgreSQL connection pool configuration
PGHOST=localhost
PGPORT=5432
